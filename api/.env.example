# Sao chép file này thành .env và điền giá trị thật
# Khóa API của Resend (lấy tại https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Email nhận tin nhắn từ form liên hệ
TO_EMAIL=ban@example.com

# Email gửi đi (phải thuộc domain đã xác thực trên Resend).
# Có thể dùng domain test mặc định của Resend khi chưa cấu hình domain riêng.
FROM_EMAIL=Portfolio <onboarding@resend.dev>
